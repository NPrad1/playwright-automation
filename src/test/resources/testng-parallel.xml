<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    ✅ CHANGED: parallel="classes" → parallel="methods"
    WHY: classes runs tests in a class sequentially on one thread
         methods runs every test method on any available thread
         With 6 classes and 6 threads = true parallelism

    ✅ CHANGED: thread-count="3" → thread-count="6"
    WHY: You have 6 test classes
         thread-count=6 means all classes can run simultaneously
         thread-count=3 meant 3 classes waited for first 3 to finish
-->
<suite name="Full Suite Parallel"
       parallel="classes"
       thread-count="3"
       verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.playwright.qa.listener.ExecutionTimeListener"/>
        <listener class-name="com.playwright.qa.listener.AllureReportListener"/>
        <listener class-name="com.playwright.qa.listener.ArtifactReporter"/>
        <listener class-name="com.playwright.qa.listener.ExtentListener"/>
        <listener class-name="com.playwright.qa.listener.RetryListener"/>
    </listeners>

    <!-- ✅ NEW: browser parameter added -->
    <parameter name="browser" value="chromium"/>

    <test name="Parallel Tests">
        <classes>
      
           <class name="com.playwright.qa.test.NewUserSignUpTest"/>
            <class name="com.playwright.qa.test.LoginTest"/>
            <class name="com.playwright.qa.test.DashboardPageTest"/>
            <class name="com.playwright.qa.test.LandingPageTest"/>
            <class name="com.playwright.qa.test.CartPageTest"/>
            <class name="com.playwright.qa.test.ManageCoursesTest"/>
           
        </classes>
    </test>

</suite>