<!-- 
    FIX #3: Added parallel="methods" so thread-count="5" actually works.
    Without parallel attribute, TestNG ignores thread-count entirely.
 -->
<suite name="Suite Smoke" verbose="1" parallel="classes" thread-count="2">
<listeners>
<!--  Allure reporting  -->
<listener class-name="io.qameta.allure.testng.AllureTestNg"/>
<!-- 
            FIX #2: ArtifactReporter runs after ALL @AfterMethods complete.
            This guarantees tracePath and videoPath attributes are populated
            before trace/video links are written to the Extent Report.
         -->
<listener class-name="com.playwright.qa.listener.ArtifactReporter"/>
<!-- 
            ExtentListener and RetryListener declared here AND in @Listeners
            on BaseTest. Declaring in both places is safe — TestNG deduplicates.
            Declaring here ensures they fire even if BaseTest is not the parent.
         -->
<listener class-name="com.playwright.qa.listener.ExtentListener"/>
<listener class-name="com.playwright.qa.listener.RetryListener"/>
</listeners>
<test name="Smoke Tests">
<groups>
<run>
<include name="smoke"/>
</run>
</groups>
<classes>
<class name="com.playwright.qa.test.NewUserSignUpTest"/>
<class name="com.playwright.qa.test.LoginTest"/>
<class name="com.playwright.qa.test.DashboardPageTest"/>
<class name="com.playwright.qa.test.LandingPageTest"/>
<class name="com.playwright.qa.test.CartPageTest"/>
<class name="com.playwright.qa.test.ManageCoursesTest"/>
</classes>
</test>
</suite>