<suite name="Full Suite" parallel="tests" thread-count="3">

  <test name="Chrome">
    <parameter name="browser" value="chromium"/>
    <classes>
      <class name="com.playwright.qa.test.NewUserSignUpTest"/>
      <class name="com.playwright.qa.test.LoginTest"/>
    </classes>
  </test>

  <test name="Firefox">
    <parameter name="browser" value="firefox"/>
    <classes>
      <class name="com.playwright.qa.test.NewUserSignUpTest"/>
      <class name="com.playwright.qa.test.LoginTest"/>
    </classes>
  </test>

  <test name="WebKit">
    <parameter name="browser" value="webkit"/>
    <classes>
      <class name="com.playwright.qa.test.NewUserSignUpTest"/>
      <class name="com.playwright.qa.test.LoginTest"/>
    </classes>
  </test>

</suite>